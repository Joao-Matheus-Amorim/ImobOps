# Local Evolution API config for ImobOps.
# This value must match EVOLUTION_API_TOKEN in the root .env.
AUTHENTICATION_API_KEY=evo_imobops_2026_123456

# Local ports.
SERVER_PORT=8080

# Evolution runtime.
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
LANGUAGE=pt-BR

# Database and cache used by docker-compose.yml.
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@evolution-postgres:5432/evolution
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/0
CACHE_REDIS_PREFIX_KEY=evolution:
CACHE_REDIS_SAVE_INSTANCES=true
