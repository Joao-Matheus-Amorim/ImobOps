{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/cron/billing-daily",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/automation-dispatch",
      "schedule": "*/5 * * * *"
    }
  ]
}
