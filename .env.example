# Supabase
# Obrigatorio para persistencia real, auth e RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEFAULT_TENANCY_ID=
# URL pública do app (usada no link do convite de novos usuários por e-mail).
NEXT_PUBLIC_APP_URL=

# Rate limiting distribuido
# Recomendado para ambiente real e webhooks.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WhatsApp (Evolution API)
EVOLUTION_API_URL=
EVOLUTION_API_TOKEN=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_TOKEN=
# Resposta automática da IA a mensagens recebidas. Padrão: desligado (humano
# responde pelo inbox). Defina "true" para o bot responder sozinho.
WHATSAPP_AI_AUTOREPLY=

# IA
AI_PROVIDER=          # openai | anthropic | openrouter | mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=ImobOps

# Cobranca (Asaas)
ASAAS_API_KEY=
ASAAS_BASE_URL=       # https://api.asaas.com/v3 (prod) | https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=  # valida o webhook de pagamento
CRON_SECRET=          # protege /api/cron/billing-daily

# App
ADMIN_EMAIL=
NEXT_PUBLIC_CLIENT_PREVIEW=on
